#. Plugin Name of the plugin
#: ai-provider-for-azure-ai-foundry.php
msgid "Azure AI Foundry Connector"
msgstr "Azure AI Foundry-kobling"

#. Plugin URI of the plugin
#: ai-provider-for-azure-ai-foundry.php
msgid "https://github.com/soderlind/azure-ai-foundry"
msgstr "https://github.com/soderlind/azure-ai-foundry"

#. Description of the plugin
#: ai-provider-for-azure-ai-foundry.php
msgid "Connect WordPress to Azure AI Foundry Model Inference API for text generation, embeddings, and more."
msgstr "Koble WordPress til Azure AI Foundry Model Inference API for tekstgenerering, innbygging og mer."

#. Author of the plugin
#: ai-provider-for-azure-ai-foundry.php
msgid "Per Søderlind"
msgstr "Per Søderlind"

#. Author URI of the plugin
#: ai-provider-for-azure-ai-foundry.php
msgid "https://soderlind.no/"
msgstr "https://soderlind.no/"

#: ai-provider-for-azure-ai-foundry.php:65
msgid "Azure AI Foundry Connector: A conflicting AI client library was detected. Please deactivate the \"AI Experiments\" plugin — its outdated library overrides the version built into WordPress 7.0."
msgstr "Azure AI Foundry-kobling: Et konflikterende AI-klientbibliotek ble oppdaget. Deaktiver utvidelsen «AI Experiments» — det utdaterte biblioteket overstyrer versjonen som er innebygd i WordPress 7.0."

