msgid "Azure AI Foundry Status"
msgstr "Azure AI Foundry-status"

#: ai-provider-for-azure-ai-foundry.php:207
msgid "Internal compatibility connector for AI plugin detection."
msgstr "Intern kompatibilitetskobling for AI-utvidelsesdeteksjon."

